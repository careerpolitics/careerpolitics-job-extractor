# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Application runtime
SERVER_PORT=8080
SELENIUM_ENABLED=true
SELENIUM_NEWS_ENABLED=true
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT_SECONDS=20
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub

# Scheduler (optional)
TRENDS_SCHEDULER_ENABLED=false
TRENDS_SCHEDULER_CRON=0 0 * * * *
TRENDS_SCHEDULER_TREND_COOLDOWN_HOURS=24

# Required for trend article generation
OPENROUTER_API_KEY=replace-me
CAREERPOLITICS_ARTICLE_API_URL=https://example.com/api/articles
CAREERPOLITICS_ARTICLE_API_TOKEN=replace-me-optional

# Optional external services
AWS_REGION=us-east-1
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/careerpolitics
# SPRING_DATASOURCE_USERNAME=careerpolitics
# SPRING_DATASOURCE_PASSWORD=replace-me
