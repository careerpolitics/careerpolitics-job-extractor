# ========================
# DATABASE
# ========================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/careerpoliticsdb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
DB_POOL_MAX_SIZE=3
DB_POOL_MIN_IDLE=1

# ========================
# HONEYBADGER
# ========================
HONEYBADGER_API_KEY=
HONEYBADGER_ENVIRONMENT=production
HONEYBADGER_LOGGING_ENABLED=true

# ========================
# GOOGLE / TRENDING
# ========================
GOOGLE_TRENDS_URL=https://trends.google.com/trending
TRENDING_DEFAULT_MAX_TRENDS=5
TRENDING_FALLBACK_TRENDS=

GOOGLE_SEARCH_URL=https://www.google.com/search
TRENDING_DEFAULT_MAX_NEWS_PER_TREND=4

# ========================
# SELENIUM
# ========================
SELENIUM_ENABLED=true
SELENIUM_NEWS_ENABLED=true
SELENIUM_HEADLESS=true
SELENIUM_MANUAL_VERIFICATION_WAIT_ENABLED=false
SELENIUM_MANUAL_VERIFICATION_MAX_WAIT_SECONDS=45
SELENIUM_TIMEOUT_SECONDS=20
SELENIUM_MAX_ATTEMPTS=2
SELENIUM_INTERACTION_DELAY_MS=750
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub
SELENIUM_USER_AGENT=
SELENIUM_PROXY_POOL=
SELENIUM_SESSION_RETRY_BACKOFF=2s

# ========================
# OPENROUTER (AI)
# ========================
OPENROUTER_ENABLED=false
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_TIMEOUT=20s

# ========================
# PUBLISHING
# ========================
CAREERPOLITICS_PUBLISHING_ENABLED=true
CAREERPOLITICS_ARTICLE_API_URL=
CAREERPOLITICS_ARTICLE_API_TOKEN=
CAREERPOLITICS_ARTICLE_ORGANIZATION_ID=
CAREERPOLITICS_ARTICLE_API_TIMEOUT=10s

# ========================
# SCHEDULER (IMPORTANT)
# ========================
TRENDING_SCHEDULER_ENABLED=true
TRENDING_SCHEDULER_CRON='0 0 * * * *'
TRENDING_SCHEDULER_GEO=IN
TRENDING_SCHEDULER_LANGUAGE=en-IN
TRENDING_SCHEDULER_MAX_TRENDS=3
TRENDING_SCHEDULER_MAX_NEWS_PER_TREND=5
TRENDING_SCHEDULER_TREND_COOLDOWN_HOURS=48
TRENDING_SCHEDULER_PUBLISH=true

# ========================
# SERVER
# ========================
PORT=8080
