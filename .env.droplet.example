# Required
OPENROUTER_API_KEY=your_openrouter_api_key
CAREERPOLITICS_CONTENT_ARTICLE_API_URL=https://your-article-api-url
CAREERPOLITICS_CONTENT_ARTICLE_API_TOKEN=your-article-api-token

# Optional database settings (if using Postgres)
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/careerpolitics
# SPRING_DATASOURCE_USERNAME=careerpolitics
# SPRING_DATASOURCE_PASSWORD=change_me

# Optional runtime tuning
# CAREERPOLITICS_CONTENT_SELENIUM_TIMEOUT_SECONDS=20
# CAREERPOLITICS_CONTENT_SELENIUM_MAX_ATTEMPTS=3
# CAREERPOLITICS_CONTENT_TRENDS_SCHEDULER_ENABLED=false
